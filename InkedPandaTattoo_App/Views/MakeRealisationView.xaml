<Window x:Class="InkedPandaTattoo_App.Views.MakeRealisationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InkedPandaTattoo_App.Views"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="MakeRealisationView" Height="450" Width="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Créer une réalisation"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <Border Grid.Row="1"
                CornerRadius="12"
                BorderThickness="1"
                BorderBrush="#DDDDDD"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Titre -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Titre"
                           VerticalAlignment="Center"
                           Margin="0,0,10,10"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         Height="32"
                         Margin="0,0,0,10"
                         Text="{Binding Titre, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Description -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Description"
                           VerticalAlignment="Top"
                           Margin="0,0,10,10"/>
                <TextBox Grid.Row="1" Grid.Column="1"
                         Height="110"
                         Margin="0,0,0,10"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- ImageUrl -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Image URL"
                           VerticalAlignment="Center"
                           Margin="0,0,10,10"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                         Height="32"
                         Margin="0,0,0,10"
                         Text="{Binding ImageUrl, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Aperçu (safe : ne crash pas si vide/null) -->
                <TextBlock Grid.Row="3" Grid.Column="0"
                           Text="Aperçu"
                           VerticalAlignment="Top"
                           Margin="0,0,10,0"/>

                <Border Grid.Row="3" Grid.Column="1"
                        Height="180"
                        CornerRadius="10"
                        BorderThickness="1"
                        BorderBrush="#EEEEEE"
                        Background="#FAFAFA"
                        Padding="6">
                    <Grid>
                        <!-- Image : on bind direct sur ImageUrl, et on n'affiche rien si vide/null -->
                        <Image Stretch="UniformToFill">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Source" Value="{x:Null}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ImageUrl}" Value="{x:Null}">
                                            <Setter Property="Source" Value="{x:Null}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ImageUrl}" Value="{x:Static sys:String.Empty}">
                                            <Setter Property="Source" Value="{x:Null}"/>
                                        </DataTrigger>

                                        <!-- Quand ImageUrl n'est ni null ni vide, WPF convertit string -> ImageSource -->
                                        <!-- (fonctionne pour http(s)://..., file://..., pack://...) -->
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ImageUrl}" Value="{x:Null}" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Source" Value="{x:Null}"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>

                            <Image.Source>
                                <Binding Path="ImageUrl" />
                            </Image.Source>
                        </Image>

                        <!-- Placeholder si pas d'image -->
                        <TextBlock Text="Aucune image"
                                   Foreground="#888"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ImageUrl}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ImageUrl}" Value="{x:Static sys:String.Empty}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- Boutons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button Content="Annuler"
                    Width="110"
                    Height="34"
                    Margin="0,0,10,0"/>
            <Button Content="Enregistrer"
                    Width="130"
                    Height="34"/>
        </StackPanel>

    </Grid>
</Window>
