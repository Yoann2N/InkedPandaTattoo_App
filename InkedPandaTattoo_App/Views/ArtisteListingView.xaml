<UserControl x:Class="InkedPandaTattoo_App.Views.ArtisteListingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InkedPandaTattoo_App.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        
        
        <StackPanel>
        <ListBox Name="ArtisteListBox"
                     SelectedItem="{Binding SelectedArtiste}"
                     ItemsSource="{Binding Artistes}"
                     DisplayMemberPath="Pseudo"
                     Margin="16"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="20"
            DataContext="{Binding SelectedArtiste}">
            <TextBlock Text="{Binding Id}"/>

            <TextBlock Text="Pseudo"/>
            <TextBox Text="{Binding Pseudo, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Profession"/>
            <TextBox Text="{Binding Profession, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Style"/>
            <TextBox Text="{Binding Style, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Bio"/>
            <TextBox Text="{Binding Bio, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Instagram"/>
            <TextBox Text="{Binding Instagram, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Facebook"/>
            <TextBox Text="{Binding Facebook, UpdateSourceTrigger=PropertyChanged}"/>

            <Button Content="Enregistrer"
                    Command="{Binding DataContext.SaveUserCommand, 
                RelativeSource={RelativeSource AncestorType=Grid}}"
                    Margin="0 20 0 0"/>
        </StackPanel>


    </Grid>
</UserControl>
