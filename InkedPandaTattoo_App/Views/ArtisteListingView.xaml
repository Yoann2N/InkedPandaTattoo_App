<UserControl x:Class="InkedPandaTattoo_App.Views.ArtisteListingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InkedPandaTattoo_App.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <ListBox Name="ArtisteListBox"
                     SelectedItem="{Binding SelectedArtiste}"
                     ItemsSource="{Binding Artistes}"
                     DisplayMemberPath="Pseudo"
                     Margin="16"
                     Height="400"/>
                      

    </Grid>
</UserControl>
